{
  "name": "nebula-forecast",
  "version": "2.0.0",
  "description": "App de previsão do tempo em tempo real com previsão de 5 dias",
  "main": "api.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nadiacaricatto/projeto_clima.git"
  },
  "keywords": [
    "weather",
    "forecast",
    "clima",
    "previsao",
    "javascript",
    "open-meteo"
  ],
  "author": "Ná",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nadiacaricatto/projeto_clima/issues"
  },
  "homepage": "https://github.com/nadiacaricatto/projeto_clima#readme",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "babel-jest": "^30.2.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "**/*.test.js"
    ],
    "collectCoverageFrom": [
      "api.js",
      "!node_modules/**"
    ]
  }
}